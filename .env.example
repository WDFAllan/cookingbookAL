# Copier ce fichier en .env et renseigner les valeurs pour la production.
# En local, les valeurs par défaut dans application.properties suffisent.

# Base de données PostgreSQL
DB_URL=jdbc:postgresql://<host>:5432/<database>
DB_USERNAME=<user>
DB_PASSWORD=<password>

# JWT — générer une clé base64 sécurisée (min 32 octets) :
# openssl rand -base64 48
JWT_SECRET=<base64-encoded-secret>
JWT_EXPIRATION=604800000

# CORS — URL(s) du frontend, séparées par des virgules
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Dossier d'upload (adapter selon l'hébergeur)
UPLOAD_DIR=./uploads
