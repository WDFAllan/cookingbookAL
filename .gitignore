# ------------------------------
# Maven build artifacts
# ------------------------------
target/
!**/src/main/**/target/
!**/src/test/**/target/

# ------------------------------
# Maven Wrapper (keep it!)
# ------------------------------
!.mvn/wrapper/maven-wrapper.jar
!.mvn/
!mvnw
!mvnw.cmd

# ------------------------------
# STS / Eclipse
# ------------------------------
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ------------------------------
# IntelliJ IDEA
# ------------------------------
.idea/
*.iws
*.iml
*.ipr

# ------------------------------
# NetBeans
# ------------------------------
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# ------------------------------
# Visual Studio Code
# ------------------------------
.vscode/

# ------------------------------
# Git attributes (if autogenerated)
# ------------------------------
**/.gitattributes

